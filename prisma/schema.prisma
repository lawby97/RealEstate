generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String? // display name; for new users = firstName + " " + lastName
  firstName          String?
  lastName           String?
  password           String? // hashed; only for email/password sign-in
  emailVerified      DateTime?
  image              String?
  // Onboarding (set after signup)
  age                Int? // 18–120
  investorType       String? // first_time_buyer | small_investor | experienced_investor | institutional
  investmentGoal     String? // cash_flow | appreciation | both
  investmentTimeline String? // within_6_months | 6_12_months | exploring
  firstPropertyBuyer Boolean?
  willLiveThere      Boolean?
  preferredAssetBand String? // one_to_four_units | five_plus_units | flexible
  preferredDealStage String? // existing | new_construction | either
  plansRenovations   Boolean?
  averageManagementFeePct Float?
  insuranceDefaultBasis   String? // percent_of_egi | annual_total | annual_per_unit | annual_per_sqft
  insuranceDefaultValue   Float?
  repairsDefaultBasis     String? // percent_of_egi | annual_total | annual_per_unit | annual_per_sqft
  repairsDefaultValue     Float?
  utilitiesDefaultBasis   String? // percent_of_egi | annual_total | annual_per_unit | annual_per_sqft
  utilitiesDefaultValue   Float?
  snowDefaultBasis        String? // percent_of_egi | annual_total | annual_per_unit | annual_per_sqft
  snowDefaultValue        Float?
  annualEmploymentIncome  Float?
  annualOtherIncome       Float?
  monthlyDebtPayments     Float?
  monthlyTaxesHeatingCondo Float?
  maxDownPayment          Float?
  closingCostReserve      Float?
  creditScore             Int?
  underwritingOwnerOccupied Boolean?
  rentalIncomeOffsetPct   Float?
  expectedMonthlyRentPerUnit Float?
  qualifyingRatePct       Float?
  underwritingAmortizationYears Int?
  targetCommercialRefinanceYears Int?
  targetCommercialLtvPct  Float?
  targetCommercialDscr    Float?
  onboardingCompletedAt DateTime?
  onboardingSkippedAt   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  savedLists    SavedList[]
  subscriptions Subscription[]
  properties    UserProperty[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Listings (from API / realtor.ca style) ─────────────────────────────────
model Area {
  id                     String   @id @default(cuid())
  city                   String
  province               String
  appreciationRateAnnual Float // e.g. 5.2 = 5.2% per year
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  listings Listing[]

  @@unique([city, province])
}

model Listing {
  id           String   @id @default(cuid())
  externalId   String   @unique // ID from source (e.g. DDF/MLS)
  source       String   @default("realtor_ca")
  address      String
  city         String
  province     String
  postalCode   String?
  latitude     Float?
  longitude    Float?
  price        Float
  currency     String   @default("CAD")
  propertyType String // Single Family, Multi-Family, Condo, etc.
  units        Int      @default(1) // number of units (1 = SFR, 2+ = multi)
  bedrooms     Int?
  bathrooms    Float?
  squareFeet   Float?
  lotSizeSqFt  Float?
  yearBuilt    Int?
  description  String?
  photoUrls    String? // JSON array of URLs
  listingUrl   String?
  listingStatus String   @default("active") // active, sold
  soldAt       DateTime?
  unavailableSince DateTime?
  syncScope    String?
  lastSyncRunAt DateTime?
  lastPriceChangeAt DateTime?
  isLinkActive Boolean?
  linkCheckedAt DateTime?
  linkStatusCode Int?
  linkStatusNote String?
  rawJson      String? // full payload for debugging
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  areaId       String?

  area         Area?                 @relation(fields: [areaId], references: [id], onDelete: SetNull)
  evaluation   ListingEvaluation?
  listItems    SavedListItem[]
  priceHistory ListingPriceHistory[]
  profile      ListingProfile?
  sources      ListingSource[]
}

model ListingSource {
  id                String   @id @default(cuid())
  listingId         String
  source            String
  externalId        String
  syncScope         String?
  address           String?
  price             Float?
  propertyType      String?
  units             Int?
  listingUrl        String?
  photoUrls         String?
  rawJson           String?
  capturedAt        DateTime?
  listingStatus     String   @default("active")
  unavailableSince  DateTime?
  lastSeenAt        DateTime @default(now())
  lastPriceChangeAt DateTime?
  isLinkActive      Boolean?
  linkCheckedAt     DateTime?
  linkStatusCode    Int?
  linkStatusNote    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([source, externalId])
  @@index([listingId])
  @@index([source, listingStatus])
}

// Normalized property profile for strategy engine (canonical; user does not edit)
model ListingProfile {
  id                     String   @id @default(cuid())
  listingId              String   @unique
  normalizedAssetType    String
  normalizedUnits        Int
  assetTypeConfidence    String
  unitsConfidence        String
  residentialUseCategory String
  residentialShareEstimated Float?
  redevelopmentCandidate Boolean @default(false)
  strategyEligibilityFlags String?
  normalizationNotes     String?
  normalizationVersion   String   @default("1")
  reviewStatus           String   @default("auto")
  provenanceByField      String?
  marketCityId           String?
  marketZoneId           String?
  zoneMatchMethod        String?
  zoneMatchConfidence    Float?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  listing    Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  marketCity MarketCity?  @relation(fields: [marketCityId], references: [id], onDelete: SetNull)
  marketZone MarketZone?  @relation(fields: [marketZoneId], references: [id], onDelete: SetNull)
}

// ─── CMHC Rent Market Report – market data layer ─────────────────────────────
model MarketCity {
  id                String   @id @default(cuid())
  city              String
  province          String
  normalizedCityName String
  cmhcMarketName    String?
  datasetSlug       String?
  datasetYear       Int?
  datasetVersion    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  zones         MarketZone[]
  metrics       MarketMetric[]
  postalMaps    MarketPostalZoneMap[]
  listingProfiles ListingProfile[]

  @@unique([city, province])
}

model MarketZone {
  id             String   @id @default(cuid())
  marketCityId   String
  zoneCode       String
  zoneLabel      String
  zoneDisplayName String?
  zoneOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  marketCity   MarketCity   @relation(fields: [marketCityId], references: [id], onDelete: Cascade)
  metrics      MarketMetric[]
  postalMaps   MarketPostalZoneMap[]
  listingProfiles ListingProfile[]

  @@unique([marketCityId, zoneCode])
}

model MarketPostalZoneMap {
  id           String   @id @default(cuid())
  marketCityId String
  postalCode   String?
  postalFsa    String
  zoneId       String
  confidence   Float    @default(1)
  source       String
  isExact      Boolean  @default(false)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  marketCity MarketCity @relation(fields: [marketCityId], references: [id], onDelete: Cascade)
  zone       MarketZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([marketCityId, postalFsa])
  @@index([marketCityId, postalCode])
}

model MarketMetricSource {
  id            String   @id @default(cuid())
  workbookFile  String
  worksheetName String
  tableNumber   String?
  city          String?
  importedAt    DateTime @default(now())
  parserVersion String   @default("1")
}

model MarketMetric {
  id                  String   @id @default(cuid())
  marketCityId        String
  zoneId              String?
  metricType          String
  assetClass          String
  bedroomType         String
  structureSizeBucket String?
  yearBuiltBucket     String?
  value               Float?
  surveyYear          Int
  sourceSheet         String?
  sourceTable         String?
  qualityFlag         String?
  suppressionFlag     Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  marketCity MarketCity  @relation(fields: [marketCityId], references: [id], onDelete: Cascade)
  zone       MarketZone? @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([marketCityId, zoneId, metricType, assetClass, bedroomType])
}

// Cache price snapshots so we can show how prices evolve over time
model ListingPriceHistory {
  id         String   @id @default(cuid())
  listingId  String
  price      Float
  recordedAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, recordedAt])
}

// Investor evaluation (cashflow + equity growth)
model ListingEvaluation {
  id                String   @id @default(cuid())
  listingId         String   @unique
  cashflowScore     Float // e.g. 0–100
  equityGrowthScore Float // 0–100
  combinedScore     Float // weighted for "best for investors"
  cashflowNotes     String?
  equityNotes       String?
  computedAt        DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

// User-created saved lists (e.g. "Toronto triplexes", "Under 500k")
model SavedList {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items SavedListItem[]
}

model SavedListItem {
  id          String   @id @default(cuid())
  savedListId String
  listingId   String
  addedAt     DateTime @default(now())
  note        String?

  savedList SavedList @relation(fields: [savedListId], references: [id], onDelete: Cascade)
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([savedListId, listingId])
}

// Subscription (Stripe) for paid access to "best" listings
model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               String // active, canceled, past_due, etc.
  priceId              String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// User's owned properties (for non–first-time buyers onboarding)
model UserProperty {
  id            String    @id @default(cuid())
  userId        String
  address       String
  city          String
  province      String
  postalCode    String?
  propertyType  String // e.g. Single Family, Condo, Multi-Family
  units         Int       @default(1)
  bedrooms      Int?
  bathrooms     Float?
  squareFeet    Float?
  lotSizeSqFt   Float?
  yearBuilt     Int?
  purchasePrice Float?
  purchaseDate  DateTime?
  currentValue  Float?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
